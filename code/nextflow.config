// Nextflow configuration for the hospital x population inhomogeneous-K pipeline.
// Three executor profiles; the processes are identical across them.

manifest {
    name        = 'hospital_kcross'
    description = 'Inhomogeneous K-function test of US hospital distribution vs population, per commuting zone'
    mainScript  = 'main.nf'
    nextflowVersion = '>=24.0'
}

// Per-task resources. The R engine runs single-threaded per zone; parallelism
// is across zones (queueSize). Bump cpus only if a process is parallelized.
process {
    cpus = 1
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    maxRetries = 2
}

profiles {
    // Laptop / workstation: run many zones concurrently on local cores.
    local {
        process.executor = 'local'
        executor.queueSize = 8        // concurrent zones; raise to ~ (cores - 2)
    }
    // HPC via SLURM.
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        process.memory   = '4 GB'
        process.time     = '2h'
        executor.queueSize = 200
    }
    // AWS Batch (set queue + workDir s3 bucket before use).
    awsbatch {
        process.executor = 'awsbatch'
        process.queue    = 'TODO-batch-queue'
        process.memory   = '4 GB'
        aws.region       = 'us-east-1'
        // workDir = 's3://your-bucket/hospital_kcross/work'
    }
}

// Provenance: report, timeline, trace under output/_nf/ (overwritten each run).
report   { enabled = true; file = "${projectDir}/../output/_nf/report.html";   overwrite = true }
timeline { enabled = true; file = "${projectDir}/../output/_nf/timeline.html"; overwrite = true }
trace    { enabled = true; file = "${projectDir}/../output/_nf/trace.txt";     overwrite = true }
